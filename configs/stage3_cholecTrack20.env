# Stage 3: CholecTrack20 trajectory-prompt finetuning — additive LoRA on top of Stage 2
#
# Key design changes vs. naive sequential fine-tuning:
#   1. LR = 2e-6 (25× lower than Stage 1) — very conservative to preserve Stage-1+2 knowledge
#   2. MAX_STEPS = 500 (short run; checkpoints every 100 steps)
#   3. LORA_RANK = 8, last 10 of 30 blocks only — minimal footprint
#   4. FROZEN_LORA_CKPT — Stage-2 LoRA fused into base weights (which already contain Stage-1)
#   5. REPLAY_RATIO = 0.20 — 20 % of batches replay Cholec80
#   6. PROMPT_PREFIX — prepends "Endoscopic surgical scene." to Track20 trajectory prompts
#   7. COND_LEN / GEN_LEN unified with Stage 1 (41 / 40)

export WAN_ROOT="/home/xuecheng/WAN_clean"
export DIFFSYNTH_ROOT="/home/xuecheng/WAN_clean/DiffSynth-Studio"
export CKPT_DIR="/mnt/data3/zhongqirui/WAN2_2"
export PYTHON_BIN="/mnt/data3/zhongqirui/env/SAM/bin/python"
export ACCELERATE_BIN="/mnt/data3/zhongqirui/env/SAM/bin/accelerate"

export TASK="wan2.2-ti2v-5b"
export SIZE="832*480"

# CholecTrack20 root
export DATASET_ROOT="/mnt/data3/zhongqirui/cholecTrack20"
export SPLITS="Training"
export FRAMES_DIRNAME="Frames"
export FRAME_EMBED_DIRNAME="text_embeds_frames"
export PROMPT_PATTERN="*_prompts.json"
export PROMPT_MATCH="exact"
export PROMPT_STRICT=1
export SAMPLE_STRIDE=1

# Scene-description prefix prepended to every Track20 trajectory prompt.
export PROMPT_PREFIX="Endoscopic surgical scene."

# Unified COND_LEN / GEN_LEN with Stage 1
export COND_LEN=41
export GEN_LEN=40
export FRAME_STEP=1

# ── Additive LoRA stacking ────────────────────────────────────────────────────
# Stage-2 LoRA delta is fused into base weights before Stage-3 LoRA is added.
# Use ${VAR:-default} so the unified script (50_train_all_stages.sh) can override
# FROZEN_LORA_CKPT / FROZEN_LORA_RANK / FROZEN_LORA_ALPHA from the outside.
# Update the default path below to point at your actual Stage-2 final checkpoint.
_S2_DEFAULT_CKPT="/home/xuecheng/WAN_clean/outputs/stage2/finetune_ckpts/c41_g40_s2_20260524_122831/step-800.safetensors"
export FROZEN_LORA_CKPT="${FROZEN_LORA_CKPT:-${_S2_DEFAULT_CKPT}}"
export FROZEN_LORA_RANK="${FROZEN_LORA_RANK:-16}"
export FROZEN_LORA_ALPHA="${FROZEN_LORA_ALPHA:-16}"

# ── Data replay ───────────────────────────────────────────────────────────────
# 20 % of batches replay Cholec80 to rehearse Stage-1 video-generation objective.
export REPLAY_VIDEO_DIR="/mnt/data3/zhongqirui/Cholec80"
export REPLAY_RATIO=0.20
export REPLAY_PROMPT="Endoscopic surgical scene, realistic continuous motion, plausible tool and tissue dynamics, steady camera."

# ── Training hyper-parameters ────────────────────────────────────────────────
export MAX_STEPS=500
export BATCH_SIZE=1
export DATASET_NUM_WORKERS=0
export LR=2e-6
export WD=0.01
export SEED=42
export LOG_INTERVAL=10
export SAVE_INTERVAL=100
export OUT_DIR="/home/xuecheng/WAN_clean/outputs/stage3_track20/finetune_ckpts"
export PLOT_INTERVAL=1
export METRICS_CSV="${OUT_DIR}/train_metrics.csv"
export METRICS_SVG="${OUT_DIR}/train_loss.svg"
export PROGRESS_JSON="${OUT_DIR}/progress.json"
export PROGRESS_SVG="${OUT_DIR}/train_progress.svg"
export PROGRESS_INTERVAL=1
export DISABLE_PROGRESS_BAR=0
export MIXED_PRECISION="bf16"
export TILED=0

# ── LoRA configuration ────────────────────────────────────────────────────────
# rank 8, restricted to last 10 of 30 blocks — minimal footprint.
export USE_LORA=1
export LORA_RANK=8
export LORA_ALPHA=8
export LORA_DROPOUT=0.0
export LORA_LAST_N_BLOCKS=10
export LORA_KEYWORDS="q,k,v,o,ffn.0,ffn.2"
export LORA_TARGET_MODULES="q,k,v,o,ffn.0,ffn.2"

# ── Stability ─────────────────────────────────────────────────────────────────
export GRAD_CLIP=1.0
export WARMUP_STEPS=30
export CFG_DROPOUT_P=0.1

# ── Distributed launch ────────────────────────────────────────────────────────
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-1,2}"
export NPROC_PER_NODE=2
export NNODES=1
export NODE_RANK=0
export MASTER_ADDR=127.0.0.1
export MASTER_PORT=29500
export NCCL_P2P_DISABLE=1
export NCCL_IB_DISABLE=1
export ACCELERATE_CONFIG=""
export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"
