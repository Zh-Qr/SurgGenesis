# Stage 1: Cholec80 fixed prompt finetuning with DiffSynth-Studio Wan2.2-TI2V-5B

export WAN_ROOT="/home/xuecheng/WAN_clean"
export DIFFSYNTH_ROOT="/home/xuecheng/WAN_clean/DiffSynth-Studio"
export CKPT_DIR="/mnt/data3/zhongqirui/WAN2_2"
export PYTHON_BIN="/mnt/data3/zhongqirui/env/SAM/bin/python"
export ACCELERATE_BIN="/mnt/data3/zhongqirui/env/SAM/bin/accelerate"

export TASK="wan2.2-ti2v-5b"
export SIZE="832*480"

export TRAIN_VIDEO_DIR="/mnt/data3/zhongqirui/Cholec80"
# Optional frame-folder source. If set non-empty, stage1 script will use frames instead of videos.
export TRAIN_FRAMES_ROOT=""

export PROMPT="Endoscopic surgical scene, realistic continuous motion, plausible tool and tissue dynamics, steady camera."
export N_PROMPT=""

export TEXT_EMBED_PATH="/home/xuecheng/WAN_clean/outputs/stage1/text_embeds.pt"  # legacy; DiffSynth trainer encodes PROMPT online

# Optional strict 1:1 clip-text alignment.
# If enabled, training uses the embedding of each sampled clip's first frame
# instead of random/fixed prompt sampling.
export SLICE_PROMPT_EMBED_ROOT=""
export SLICE_PROMPT_EMBED_DIRNAME="text_embeds_frames"
export SLICE_PROMPT_MATCH="exact"
export SLICE_PROMPT_FRAME_ID_OFFSET=1
export SLICE_PROMPT_STRICT=1

export COND_LEN=41
export GEN_LEN=40
export FRAME_STEP=1
export PAD_MODE="repeat_last"
export FUTURE_FILL="black"

# Stage1 convergence path: match stage3 objective (rollout + latent reconstruction loss).
export TRAIN_OBJECTIVE="rollout_l1"
export SOLVER="unipc"
export STEPS=20
export SHIFT=16.0
export GUIDE=3.0
export CONTEXT_SCALE=1.0
export TRAIN_LAST_N_STEPS=1
export DENOISE_LOG_INTERVAL=0

# One-step flow-matching sigma range.
# Raise sigma_min for early-stage stability; can relax back to 0.02 after initial convergence.
export FM_SIGMA_MIN=0.05
export FM_SIGMA_MAX=0.98
# Prefer curriculum over fixed sigma for stage1 convergence.
# Fixed sigma can look stable but often plateaus early.
export FM_SIGMA_SAMPLING="curriculum"
export FM_SIGMA_MIN_START=0.70
export FM_SIGMA_CURRICULUM_STEPS=1200
export FM_FIXED_SIGMA=0.60

export MAX_STEPS=2000
export BATCH_SIZE=1
export DATASET_NUM_WORKERS=0
export LR=5.0e-5
export WD=0.01
export SEED=42
export LOG_INTERVAL=10
export SAVE_INTERVAL=500
export OUT_DIR="/home/xuecheng/WAN_clean/outputs/stage1/finetune_ckpts"
export PLOT_INTERVAL=1
export METRICS_CSV="${OUT_DIR}/train_metrics.csv"
export METRICS_SVG="${OUT_DIR}/train_loss.svg"
export PROGRESS_JSON="${OUT_DIR}/progress.json"
export PROGRESS_SVG="${OUT_DIR}/train_progress.svg"
export PROGRESS_INTERVAL=1
export DISABLE_PROGRESS_BAR=0
export MIXED_PRECISION="bf16"
export TILED=0
export LOSS_TYPE="l1"
export LOSS_HUBER_DELTA=0.05
export LOSS_EMA_DECAY=0.98

export CUDA_VISIBLE_DEVICES=1,2
export NPROC_PER_NODE=2
export NNODES=1
export NODE_RANK=0
export MASTER_ADDR=127.0.0.1
export MASTER_PORT=29500
export NCCL_P2P_DISABLE=1
export NCCL_IB_DISABLE=1
# Optional accelerate config file, e.g. a DeepSpeed/ZeRO config for larger runs.
export ACCELERATE_CONFIG=""

# LoRA fine-tuning (recommended to avoid OOM)
export USE_LORA=1
export LORA_RANK=32
export LORA_ALPHA=32
export LORA_DROPOUT=0.0
export LORA_LAST_N_BLOCKS=8
export LORA_KEYWORDS="q,k,v,o,ffn.0,ffn.2"
export LORA_TARGET_MODULES="q,k,v,o,ffn.0,ffn.2"

# --- Stability fixes ---
# Gradient clipping
export GRAD_CLIP=1.0
# LR warmup steps
export WARMUP_STEPS=200
# CFG dropout during training
export CFG_DROPOUT_P=0.0
