# Stage 2: CholecT50 triplet-prompt finetuning — additive LoRA on top of Stage 1
#
# Key design changes vs. naive sequential fine-tuning:
#   1. LR = 5e-6 (10× lower than Stage 1) — prevents catastrophic forgetting
#   2. MAX_STEPS = 800 (shorter run; checkpoints every 100 steps for best-ckpt selection)
#   3. LORA_RANK = 16, last 20 of 30 blocks only — limits plasticity
#   4. FROZEN_LORA_CKPT — Stage-1 LoRA fused into base weights before Stage-2 LoRA is added
#   5. REPLAY_RATIO = 0.20 — 20 % of batches replay Cholec80 to rehearse Stage-1 objective
#   6. PROMPT_PREFIX — prepends "Endoscopic surgical scene." to CholecT50 triplet prompts
#   7. COND_LEN / GEN_LEN unified with Stage 1 (41 / 40)

export WAN_ROOT="/home/xuecheng/WAN_clean"
export DIFFSYNTH_ROOT="/home/xuecheng/WAN_clean/DiffSynth-Studio"
export CKPT_DIR="/mnt/data3/zhongqirui/WAN2_2"
export PYTHON_BIN="/mnt/data3/zhongqirui/env/SAM/bin/python"
export ACCELERATE_BIN="/mnt/data3/zhongqirui/env/SAM/bin/accelerate"

export TASK="wan2.2-ti2v-5b"
export SIZE="832*480"

# CholecT50 root
export CHOLECT50_ROOT="/mnt/data3/zhongqirui/CholecT50"
export CHOLECT50_VIDEOS_ROOT="${CHOLECT50_ROOT}/videos"

export TRAIN_VIDEO_DIR=""
export TRAIN_FRAMES_ROOT="${CHOLECT50_VIDEOS_ROOT}"

# Prompt JSON settings (1:1 clip-frame alignment)
export PROMPT_PATTERN="*_prompts.json"
export SLICE_PROMPT_MATCH="exact"
export SLICE_PROMPT_FRAME_ID_OFFSET=1
export SLICE_PROMPT_STRICT=1

# Scene-description prefix prepended to every CholecT50 triplet prompt.
# Bridges the text-distribution gap between Stage-1 fixed prompt and Stage-2 structured prompts.
export PROMPT_PREFIX="Endoscopic surgical scene."

# Unified COND_LEN / GEN_LEN with Stage 1
export COND_LEN=41
export GEN_LEN=40
export FRAME_STEP=1
export PAD_MODE="repeat_last"

# ── Additive LoRA stacking ────────────────────────────────────────────────────
# Stage-1 LoRA delta is fused permanently into base weights before Stage-2 LoRA
# is injected.  Stage-1 knowledge is never overwritten; Stage-2 learns the residual.
# Use ${VAR:-default} so 50_train_all_stages.sh can override from the outside.
_S1_DEFAULT_CKPT="/home/xuecheng/WAN_clean/outputs/stage1/finetune_ckpts/c41_g40_20260521_173514/step-2000.safetensors"
export FROZEN_LORA_CKPT="${FROZEN_LORA_CKPT:-${_S1_DEFAULT_CKPT}}"
export FROZEN_LORA_RANK="${FROZEN_LORA_RANK:-32}"
export FROZEN_LORA_ALPHA="${FROZEN_LORA_ALPHA:-32}"

# ── Data replay ───────────────────────────────────────────────────────────────
# 20 % of training batches are drawn from Cholec80 with the Stage-1 fixed prompt.
export REPLAY_VIDEO_DIR="/mnt/data3/zhongqirui/Cholec80"
export REPLAY_RATIO=0.20
export REPLAY_PROMPT="Endoscopic surgical scene, realistic continuous motion, plausible tool and tissue dynamics, steady camera."

# ── Training hyper-parameters ────────────────────────────────────────────────
export MAX_STEPS=800
export BATCH_SIZE=1
export DATASET_NUM_WORKERS=0
export LR=5e-6
export WD=0.01
export SEED=42
export LOG_INTERVAL=10
export SAVE_INTERVAL=100
export OUT_DIR="/home/xuecheng/WAN_clean/outputs/stage2/finetune_ckpts"
export PLOT_INTERVAL=1
export METRICS_CSV="${OUT_DIR}/train_metrics.csv"
export METRICS_SVG="${OUT_DIR}/train_loss.svg"
export PROGRESS_JSON="${OUT_DIR}/progress.json"
export PROGRESS_SVG="${OUT_DIR}/train_progress.svg"
export PROGRESS_INTERVAL=1
export DISABLE_PROGRESS_BAR=0
export MIXED_PRECISION="bf16"
export TILED=0

# ── LoRA configuration ────────────────────────────────────────────────────────
# rank 16 (vs Stage-1's 32), restricted to last 20 of 30 blocks.
export USE_LORA=1
export LORA_RANK=16
export LORA_ALPHA=16
export LORA_DROPOUT=0.0
export LORA_LAST_N_BLOCKS=20
export LORA_KEYWORDS="q,k,v,o,ffn.0,ffn.2"
export LORA_TARGET_MODULES="q,k,v,o,ffn.0,ffn.2"

# ── Stability ─────────────────────────────────────────────────────────────────
export GRAD_CLIP=1.0
export WARMUP_STEPS=50
export CFG_DROPOUT_P=0.1

# ── Distributed launch ────────────────────────────────────────────────────────
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-1,2}"
export NPROC_PER_NODE=2
export NNODES=1
export NODE_RANK=0
export MASTER_ADDR=127.0.0.1
export MASTER_PORT=29500
export NCCL_P2P_DISABLE=1
export NCCL_IB_DISABLE=1
export ACCELERATE_CONFIG=""
